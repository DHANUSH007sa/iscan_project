# iScan Configuration Template
# Copy this file to .env.local and update with your values
# DO NOT commit .env.local to git

# ============ BACKEND CONFIGURATION ============
FLASK_ENV=development
FLASK_DEBUG=0
FLASK_PORT=5001

# ============ ADMIN USER ============
# These are for the default admin user created on first run
# Change these to your desired admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=demo_password_change_in_production

# ============ DATABASE ============
# Path where SQLite database will be stored
DATABASE_PATH=./backend/auth.db

# ============ SCANNER SETTINGS ============
# Set to 1 to use simulated scan results (no external tools needed)
PISHIELD_SIMULATE_SCANS=0

# Set to 1 to enable full nmap capabilities (requires sudo/root)
ISCAN_FORCE_ROOT=0

# ============ FRONTEND CONFIGURATION ============
# API base URL for frontend
VITE_API_URL=http://localhost:5001
NODE_ENV=development

# ============ CORS SETTINGS ============
# Allowed origins for API requests
CORS_ORIGIN=http://localhost:8080

# ============ LOGGING ============
LOG_LEVEL=INFO
